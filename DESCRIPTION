Package: cdCAT
Type: Package
Title: Computerized Adaptive Testing with Cognitive Diagnostic Models
Version: 0.1.0
Authors@R: c(
    person(
      "Thiago", "Miranda",
      email = "thiagofm.pa@gmail.com",
      role = c("aut", "cre")
    ),
    person(
      "Bruno", "Silvestre",
